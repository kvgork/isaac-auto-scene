# Python
__pycache__/
*.pyc
*.pyo
*.pyd

# Test / lint caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# Build artefacts
dist/
build/
*.egg-info/

# Virtual envs
.venv/
.pixi/

# Project outputs
outputs/
logs/

# Large assets (tracked via Git LFS or excluded entirely)
assets/*.usd
tests/fixtures/*.ply

# IDE
.idea/
.vscode/
*.swp
*.swo

# Open3D Visualizer screen captures (created on Ctrl+S / Ctrl+P in the viewer)
ScreenCamera_*.json
ScreenCapture_*.png

# Hardware-specific calibration artefacts live in ~/.config/isaac-auto-scene/
# (set-home, manual-align, manual-align-all default writers).  This entry is
# kept as a safety net for any legacy file that may still be in assets/.
assets/home_offset.json
